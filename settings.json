{
  "respectGitignore": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "OMC_DISABLE_TOOLS": "wiki,memory"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(./.env.example)",
      "Read(./credentials.example.json)",
      "Read(./secrets.example.json)",
      "Read(./.dev.vars.example)",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.development.local)",
      "Read(./.env.test)",
      "Read(./.env.test.local)",
      "Read(./.env.production)",
      "Read(./.env.production.local)",
      "Read(./.env.staging)",
      "Read(./.env.staging.local)",
      "Read(./.env.ci)",
      "Read(./.env.docker)",
      "Read(./.env.backup)",
      "Read(./.env.bak)",
      "Read(./.env.old)",
      "Read(./credentials.json)",
      "Read(./secrets.json)",
      "Read(./secrets.local.json)",
      "Read(./secrets.development.json)",
      "Read(./secrets.test.json)",
      "Read(./secrets.production.json)",
      "Read(./secrets.staging.json)",
      "Read(./secrets.backup.json)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.development)",
      "Read(./**/.env.development.local)",
      "Read(./**/.env.test)",
      "Read(./**/.env.test.local)",
      "Read(./**/.env.production)",
      "Read(./**/.env.production.local)",
      "Read(./**/.env.staging)",
      "Read(./**/.env.staging.local)",
      "Read(./**/.env.ci)",
      "Read(./**/.env.docker)",
      "Read(./**/.env.backup)",
      "Read(./**/.env.bak)",
      "Read(./**/.env.old)",
      "Read(./**/secrets.json)",
      "Read(./**/secrets.local.json)",
      "Read(./**/secrets.development.json)",
      "Read(./**/secrets.test.json)",
      "Read(./**/secrets.production.json)",
      "Read(./**/secrets.staging.json)",
      "Read(./**/secrets.backup.json)",
      "Read(./**/credentials.json)",
      "Read(./**/.dev.vars)",
      "Read(./**/.dev.vars.production)",
      "Read(./**/.dev.vars.staging)",
      "Read(./**/.dev.vars.development)",
      "Read(./**/.dev.vars.dev)",
      "Read(./**/.dev.vars.test)",
      "Read(./**/.dev.vars.backup)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.der)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./secrets/**)",
      "Read(~/.kube/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(./config/credentials.json)",
      "Read(./node_modules/**)",
      "Read(./target/**)",
      "Read(./build/**)",
      "Read(./dist/**)",
      "Read(./out/**)",
      "Read(./vendor/**)",
      "Read(./.git/**)",
      "Read(./coverage/**)",
      "Read(./package-lock.json)",
      "Read(./yarn.lock)",
      "Read(./pnpm-lock.yaml)",
      "Read(./Cargo.lock)",
      "Read(./**/*.tfvars)",
      "Read(./**/*.tfvars.*)",

      "Read(/proc/**)",
      "Read(./**/.netrc)",
      "Read(~/.netrc)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",

      "Bash(env)",
      "Bash(env|*)",
      "Bash(printenv)",
      "Bash(printenv:*)",
      "Bash(export -p)",
      "Bash(export -p|*)",
      "Bash(declare -x)",
      "Bash(declare -x|*)",
      "Bash(declare -p)",
      "Bash(declare -p|*)",
      "Bash(set)",
      "Bash(compgen -v:*)",
      "Bash(cat /proc/*/environ)",
      "Bash(cat /proc/*/environ:*)",
      "Bash(*/proc/*/environ*)",
      "Bash(*$AWS_SECRET*)",
      "Bash(*$AWS_ACCESS_KEY*)",
      "Bash(*$GITHUB_TOKEN*)",
      "Bash(*$OPENAI_API_KEY*)",
      "Bash(*$ANTHROPIC_API_KEY*)",

      "Read(../**)",
      "Read(/etc/**)",
      "Read(/root/**)",
      "Edit(../**)",
      "Edit(/etc/**)",
      "Edit(/root/**)",
      "Edit(/usr/**)",
      "Edit(/bin/**)",
      "Write(../**)",
      "Write(/etc/**)",
      "Write(/root/**)",
      "Write(/usr/**)",
      "Write(/bin/**)",
      "Write(~/.bashrc)",
      "Write(~/.bash_profile)",
      "Write(~/.profile)",
      "Write(~/.zshrc)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm --recursive --force*)",
      "Bash(rm --force --recursive*)",
      "Bash(* rm -rf *)",
      "Bash(* rm -fr *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push * --force-with-lease*)",
      "Bash(git -C * push --force*)",
      "Bash(git -C * push -f *)",
      "Bash(git -C * push --force-with-lease*)",
      "Bash(git --git-dir=* push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git -C * reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git -C * clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git -C * branch -D*)",
      "Bash(git checkout -- *)",
      "Bash(git -C * checkout -- *)",

      "Bash(echo $*)",
      "Bash(printf *$*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.netrc)",
      "Bash(cat /etc/*)",
      "Bash(cd /*)",
      "Bash(cd ~/*)",
      "Bash(cd ..*)",
      "Bash(rm /*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(mv * /*)",
      "Bash(cp * /*)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/strip-omc-memory-hooks.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/block-secret-leak.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/reporag-dupcheck.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "reporag",
            "tool": "index_codebase",
            "input": {
              "path": "${cwd}"
            }
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/reporag-hint.py"
          }
        ]
      }
    ]
  },
  "workflowKeywordTriggerEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud-cache.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "ralph-loop@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "oh-my-claudecode@omc": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "caveman@caveman": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowUnixSockets": ["/nix/var/nix/daemon-socket/socket"]
    },
    "filesystem": {
      "allowWrite": ["~/nc", "~/nd"],
      "allowRead": ["./.git", "./.devenv"]
    },
    "bwrapPath": "/usr/bin/bwrap"
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "editorMode": "vim",
  "preferredNotifChannel": "terminal_bell",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
